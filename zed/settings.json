{
  "agent": {
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "model": "claude-opus-4.6",
      "provider": "copilot_chat",
    },
    "default_profile": "ask",
    "favorite_models": [
      {
        "enable_thinking": false,
        "model": "claude-haiku-4.5",
        "provider": "copilot_chat",
      },
      {
        "enable_thinking": false,
        "model": "claude-opus-4.6",
        "provider": "copilot_chat",
      },
      {
        "enable_thinking": false,
        "model": "claude-sonnet-4.6",
        "provider": "copilot_chat",
      },
    ],
    "model_parameters": [],
    "tool_permissions": {
      "default": "allow",
    },
  },
  "agent_buffer_font_size": 13,
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "agent_ui_font_size": 13,
  "base_keymap": "VSCode",
  "buffer_font_family": "Operator Mono",
  "buffer_font_features": {
    "calt": false,
  },
  "buffer_font_size": 13,
  "buffer_font_weight": 100,
  "buffer_line_height": "standard",
  "code_actions_on_format": {
    "source.fixAll.biome": true,
    "source.organizeImports.biome": true,
  },
  "confirm_quit": true,
  "ensure_final_newline_on_save": true,
  "hard_tabs": false,
  "preview_tabs": {
    "enable_preview_from_file_finder": false,
    "enabled": true,
  },
  "project_panel": {
    "auto_fold_dirs": false,
  },
  "relative_line_numbers": "enabled",
  "remove_trailing_whitespace_on_save": true,
  "show_whitespaces": "all",
  "tab_size": 2,
  "terminal": {
    "copy_on_select": true,
    "dock": "right",
  },
  "theme": {
    "dark": "Xcode Default Dark",
    "light": "Xcode Default Light",
    "mode": "system",
  },
  "ui_font_family": "Operator Mono",
  "ui_font_size": 13,
  "ui_font_weight": 100,
  "vim": {
    "use_system_clipboard": "on_yank",
  },
  "vim_mode": true,
  "wrap_guides": [100, 120, 80],
}
